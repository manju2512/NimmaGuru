<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F8FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:id="@+id/tvAppreciateTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/appreciate_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A5276"
            android:padding="16dp"/>

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tvAppreciateSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/appreciate_subtitle"
            android:textSize="14sp"
            android:textColor="#2874A6"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"/>

        <!-- Wall of Fame Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏆 Wall of Fame"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1A5276"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"/>

        <!-- Wall of Fame -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:id="@+id/wallOfFameLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"/>

        </HorizontalScrollView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="8dp"/>

        <!-- Notes List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvAppreciation"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"/>

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddNote"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Add Note"
        app:srcCompat="@android:drawable/ic_input_add"
        app:backgroundTint="#1A5276"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>