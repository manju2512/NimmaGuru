<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Subject -->
        <TextView
            android:id="@+id/tvSubject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mathematics"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A5276"
            android:layout_marginBottom="6dp"/>

        <!-- Guru Name -->
        <TextView
            android:id="@+id/tvSessionGuru"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Guru: Ramesh Kumar"
            android:textSize="15sp"
            android:textColor="#2874A6"
            android:layout_marginBottom="4dp"/>

        <!-- Time -->
        <TextView
            android:id="@+id/tvSessionTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Time: 10:00 AM - 12:00 PM"
            android:textSize="14sp"
            android:textColor="#27AE60"
            android:layout_marginBottom="4dp"/>

        <!-- Venue -->
        <TextView
            android:id="@+id/tvSessionVenue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Venue: Samudaya Bhavana"
            android:textSize="14sp"
            android:textColor="#555555"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>