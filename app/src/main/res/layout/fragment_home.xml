<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:background="#F0F8FF"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome to NimmaGuru"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A5276"
        android:gravity="center"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connecting Gurus with Students"
        android:textSize="15sp"
        android:textColor="#2874A6"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnRegisterGuru"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Register as Guru"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#1A5276"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

</LinearLayout>